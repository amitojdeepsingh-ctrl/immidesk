# ??? ImmigDesk ? Environment Variables ??????????????????????????????????????
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# Prisma 7 loads env vars via dotenv in prisma.config.ts.
# ????????????????????????????????????????????????????????????????????????????

# ?? Supabase ???????????????????????????????????????????????????????????????
# From Supabase Dashboard ? Project Settings ? API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# From Supabase Dashboard ? Project Settings ? API ? service_role
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ?? Database (Prisma 7 via prisma.config.ts) ???????????????????????????????
# From Supabase Dashboard ? Project Settings ? Database ? Connection string
# DATABASE_URL: Use the "Session pooler" connection string (port 6543, pooled)
# DIRECT_URL:   Use the "Direct connection" string (port 5432, for migrations)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.xxxxx.supabase.co:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.xxxxx.supabase.co:5432/postgres"

# ?? Stripe ?????????????????????????????????????????????????????????????????
# From Stripe Dashboard ? Developers ? API keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# From Stripe Dashboard ? Products ? each price's API ID
STRIPE_SOLO_PRICE_ID_USD=price_...
STRIPE_TEAM_PRICE_ID_USD=price_...
STRIPE_FIRM_PRICE_ID_USD=price_...
STRIPE_ENTERPRISE_PRICE_ID_USD=price_...
STRIPE_SOLO_PRICE_ID_INR=price_...
STRIPE_TEAM_PRICE_ID_INR=price_...

# ?? Resend (Transactional Email) ???????????????????????????????????????????
# From Resend Dashboard ? API Keys
RESEND_API_KEY=re_...

# ?? Sentry (Error Monitoring) ??????????????????????????????????????????????
# From Sentry ? Settings ? Projects ? Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_DSN=https://...@sentry.io/...
# From Sentry ? Settings ? Auth Tokens
SENTRY_AUTH_TOKEN=sntrys_...

# ?? Upstash Redis (Rate Limiting) ??????????????????????????????????????????
# From Upstash Console ? Redis ? Details ? REST API
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# ?? Cron Jobs ??????????????????????????????????????????????????????????????
# A random 64-character secret used to secure Vercel Cron job endpoints.
# Generate with: openssl rand -hex 32
CRON_SECRET=replace-with-64-char-random-secret

# ?? LiveKit (Video Consultations) ???????????????????????????????????????????
# From LiveKit Cloud ? Settings ? Keys
LIVEKIT_API_KEY=...
LIVEKIT_API_SECRET=...
# From LiveKit Cloud ? Settings ? Connect
NEXT_PUBLIC_LIVEKIT_URL=wss://xxxxx.livekit.cloud

# ?? App ????????????????????????????????????????????????????????????????????
# The public URL of your deployed application.
# Use http://localhost:3000 for local development.
NEXT_PUBLIC_APP_URL=http://localhost:3000
